# swap.emercoin.com — edge config for the swap service (EXAMPLE / reference).
#
# Why this lives in the repo (it's not the running config — that's in emercoin_docker):
# the app's per-IP anti-spam reads the real client IP from CF-Connecting-IP, then
# X-Forwarded-For, then the socket peer (see swap/web.py:_client_ip). That header is
# only trustworthy if the origin accepts traffic ONLY from Cloudflare. If the VPS is
# reachable directly, anyone can set CF-Connecting-IP by hand and forge/evade the
# per-IP rate + concurrency caps. This file documents that invariant and the routing
# split (dynamic API/MCP → app; everything else → static site). Keep the swap block in
# emercoin_docker's real Caddyfile in sync with this.

{
	# Trust Cloudflare as the upstream proxy so Caddy derives the client IP from the
	# forwarded headers instead of treating the CF edge as the client. The `cloudflare`
	# source needs a plugin:  github.com/WeidiDeng/caddy-cloudflare-ip
	#   xcaddy build --with github.com/WeidiDeng/caddy-cloudflare-ip
	# No plugin? Replace with `trusted_proxies static <CF CIDRs>` and refresh the list
	# from https://www.cloudflare.com/ips/ periodically.
	servers {
		trusted_proxies cloudflare {
			interval 12h
		}
	}
}

swap.emercoin.com {
	encode zstd gzip

	# --- Origin lock: only Cloudflare may reach this host --------------------------
	# This is what makes CF-Connecting-IP trustworthy. Enforce it at ONE of:
	#   (a) firewall — allow :443 only from Cloudflare ranges (ufw / cloud SG), or
	#   (b) Cloudflare Authenticated Origin Pulls (mTLS client cert from CF), or
	#   (c) the Caddy backstop below (static CF CIDRs; keep in sync with cloudflare.com/ips).
	# Prefer (a) or (b); (c) is defense-in-depth. Uncomment and fill to enable (c):
	#
	# @not_cloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 \
	#	103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 \
	#	197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 \
	#	172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 \
	#	2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	# respond @not_cloudflare 403

	# --- Dynamic surface → app on the swap container -------------------------------
	# Keyed service API, keyless public /web/*, liveness, and the agent MCP endpoint.
	# CF-Connecting-IP / X-Forwarded-For are forwarded to the app by default.
	@app {
		path /buy_emc /healthz
		path /order /order/*
		path /web /web/*
		path /mcp /mcp/        # MCP Streamable HTTP for AI agents (both slash forms)
	}
	reverse_proxy @app swap:8002

	# --- Static site (exchanger page, offer, stats.html, assets, llms.txt) ---------
	# In production Caddy serves the corpus; the app keeps SWAP_SERVE_STATIC=false.
	root * /srv/swap/site
	file_server
}
