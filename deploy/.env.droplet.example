# swap on the droplet — deploy/.env (chmod 600, never commit the real one).
# Staged: bring up on TESTNET (Nile) first to validate the prod plumbing
# (Caddy vhost, CF DNS, container, adapter) with no USDT risk, then flip the
# four TRON lines to MAINNET. EMC delivery is ALWAYS real (node wallet), so keep
# the reserve funded either way.

# --- adapter (shared EMC payout rail; same key as emer-ai-tools deploy/.env) ---
# SWAP_ADAPTER_URL is set in the compose (http://emer-adapter:8000).
SWAP_ADAPTER_INTERNAL_KEY=<ADAPTER_INTERNAL_KEY from emer-ai-tools/deploy/.env>

# --- TRON watcher: TESTNET (Nile) for staging --------------------------------
SWAP_TRONGRID_URL=https://nile.trongrid.io
SWAP_TRONGRID_API_KEY=<your TronGrid api key>
SWAP_USDT_CONTRACT=TNrZP5zHPQUQtscvS1SssSneKcwYZSYvrS   # Nile test token
SWAP_DEPOSIT_ADDRESS=TMU2iLbJVdaNPiMbXow47BzbjPxH8wy2sR # Nile shared deposit addr
# Watcher only READS TRON → the spend key never goes on the host. Leave the
# mnemonic empty here; derive addresses offline.
SWAP_TRON_MNEMONIC=

# --- MAINNET flip (replace the four lines above when going live) -------------
# SWAP_TRONGRID_URL=https://api.trongrid.io
# SWAP_TRONGRID_API_KEY=<mainnet TronGrid api key>
# SWAP_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t  # mainnet USDT TRC20
# SWAP_DEPOSIT_ADDRESS=<FRESH mainnet TRON address, mnemonic generated OFFLINE>

# --- economics / safety (defaults are fine) ----------------------------------
SWAP_EMC_RESERVE_CHECK=true
# SWAP_MIN_USDT=5.0
# SWAP_MAX_USDT=10.0
# SWAP_WEB_RATE_PER_MIN=6
