# --- swap configuration (copy to .env; .env is gitignored) ------------------

# Database (SQLite on start; swap to Postgres/asyncpg later — see repository.py)
SWAP_DB_PATH=./swap.db

# Emercoin adapter (RPC<->REST) — the only thing that speaks node RPC.
# EMC delivery goes through its POST /wallet/send, gated by X-Internal-Key.
SWAP_ADAPTER_URL=http://localhost:8001
SWAP_ADAPTER_INTERNAL_KEY=change-me-internal-key

# TRON watcher — TronGrid on start; own node later.
SWAP_TRONGRID_URL=https://api.trongrid.io
SWAP_TRONGRID_API_KEY=
# USDT TRC20 contract (mainnet). Testnet (Nile/Shasta) differs — override there.
SWAP_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Single shared TRON address shown to all buyers (payments matched by a unique
# per-order amount tag, NOT by address). The watcher only READS TRON, so only
# this public address is needed on the server.
SWAP_DEPOSIT_ADDRESS=
# BIP39 mnemonic that controls the deposit address. NOT needed by the running
# service — required only OFFLINE to move collected USDT to treasury/off-ramp.
# Keep it off this host; back it up offline. (Mainnet: use a FRESH mnemonic.)
SWAP_TRON_MNEMONIC=
# Treasury / off-ramp address you move collected USDT to (manual, low-volume).
SWAP_SWEEP_ADDRESS=

# Economics
SWAP_EMC_PER_USDT=10.0
SWAP_MIN_USDT=5.0
SWAP_MAX_USDT=10.0

# Settlement
SWAP_CONFIRMATIONS_REQUIRED=19
SWAP_ORDER_TTL_MINUTES=30

# Reserve monitor: proactive EMC balance log + low-reserve alert from the watcher
# loop (the order pre-flight only reacts once a buyer hits a 503). WARNs while
# available headroom (balance − obligations − buffer) is below the watermark, so
# you top up before going out of service. Watermark default ≈ 3 max-size orders.
SWAP_RESERVE_MONITOR_ENABLED=true
SWAP_RESERVE_MONITOR_INTERVAL_MINUTES=15
SWAP_RESERVE_LOW_WATERMARK=300.0

# Callbacks
SWAP_CALLBACK_MAX_RETRIES=6

# Public web channel (raw on-ramp for humans at swap.emercoin.com). The
# service-to-service API stays primary; this adds a keyless, rate-limited public
# surface backed by a first-party "web" service (auto-created on start).
SWAP_WEB_CHANNEL_ENABLED=true
SWAP_WEB_RATE_PER_MIN=6
# Serve swap/site/ (exchanger page + offer) from the app itself. Local dev only;
# in production Caddy serves the static corpus and only proxies the API here.
SWAP_SERVE_STATIC=false

# Operator contact shown to humans (page footer + problem-status prompts) and to
# agents (get_swap_config). It's the feedback channel for manual cases (aml_hold,
# expired, late/mismatched payment) — keep it monitored (e.g. forward it).
SWAP_SUPPORT_EMAIL=swap@emercoin.com

# Public stats digest (/stats.html + GET /web/stats): proof-of-reserves view.
# The endpoint is keyless and public, so a short TTL cache shields the adapter +
# TronGrid from being hit on every page load.
SWAP_STATS_CACHE_TTL_SECONDS=60

# MCP exchanger surface for AI agents: the keyless web on-ramp re-exposed as MCP
# tools (buy_emc / get_order_status / cancel_order / get_swap_config) over Streamable HTTP
# at /mcp. No key/callback — same public on-ramp as the web page; shares its
# anti-spam (global awaiting cap + per-IP rate/concurrency). Caddy already proxies
# all of swap:8002, so this is live at swap.emercoin.com/mcp with no edge change.
SWAP_MCP_ENABLED=true
# DNS-rebinding protection is for browser-driven localhost servers; the edge
# (Caddy/CF) validates Host and callers are agents, so leave it off in prod.
SWAP_MCP_DNS_REBINDING_PROTECTION=false
