# --- swap configuration (copy to .env; .env is gitignored) ------------------

# Database (SQLite on start; swap to Postgres/asyncpg later — see repository.py)
SWAP_DB_PATH=./swap.db

# Emercoin adapter (RPC<->REST) — the only thing that speaks node RPC.
# EMC delivery goes through its POST /wallet/send, gated by X-Internal-Key.
SWAP_ADAPTER_URL=http://localhost:8001
SWAP_ADAPTER_INTERNAL_KEY=change-me-internal-key

# TRON watcher — TronGrid on start; own node later.
SWAP_TRONGRID_URL=https://api.trongrid.io
SWAP_TRONGRID_API_KEY=
# USDT TRC20 contract (mainnet). Testnet (Nile/Shasta) differs — override there.
SWAP_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# HD wallet for per-order TRON deposit addresses (index = order_id).
# KEEP SECRET. 12/24-word BIP39 mnemonic. Generate offline; never commit.
SWAP_TRON_MNEMONIC=
# Consolidation / cold address that sweeps USDT land on (needs TRX for gas).
SWAP_SWEEP_ADDRESS=

# Economics
SWAP_EMC_PER_USDT=10.0
SWAP_MIN_USDT=1.0
SWAP_MAX_USDT=10.0

# Settlement
SWAP_CONFIRMATIONS_REQUIRED=19
SWAP_ORDER_TTL_MINUTES=30

# Callbacks
SWAP_CALLBACK_MAX_RETRIES=6
